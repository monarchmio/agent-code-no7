<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>Agent Code No.7 — 路演PPT</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Microsoft YaHei', 'PingFang SC', sans-serif;
            background: #0a0a1a;
            color: #e0e0e0;
            overflow: hidden;
            height: 100vh;
        }

        /* Slide Container */
        .slides { position: relative; width: 100%; height: 100vh; }
        .slide {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 60px 100px;
            opacity: 0;
            transform: translateX(50px);
            transition: all 0.5s ease;
            pointer-events: none;
        }
        .slide.active {
            opacity: 1;
            transform: translateX(0);
            pointer-events: all;
        }

        /* Navigation */
        .nav {
            position: fixed;
            bottom: 30px;
            right: 40px;
            display: flex;
            gap: 12px;
            z-index: 100;
        }
        .nav button {
            padding: 10px 20px;
            background: #1a2a4a;
            border: 1px solid #00d4ff44;
            color: #00d4ff;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
        }
        .nav button:hover { background: #0f3460; }
        .page-num {
            position: fixed;
            bottom: 36px;
            left: 40px;
            color: #555;
            font-size: 14px;
        }
        .tips {
            position: fixed;
            top: 20px;
            right: 20px;
            color: #444;
            font-size: 12px;
        }

        /* Slide Styles */
        .slide h1 {
            font-size: 52px;
            background: linear-gradient(135deg, #00d4ff, #0084ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 16px;
        }
        .slide h2 {
            font-size: 38px;
            color: #fff;
            margin-bottom: 24px;
        }
        .slide h3 {
            font-size: 28px;
            color: #00d4ff;
            margin-bottom: 20px;
            width: 100%;
        }
        .slide p {
            font-size: 22px;
            color: #aaa;
            line-height: 1.8;
            text-align: center;
        }
        .slide .subtitle {
            font-size: 26px;
            color: #ccc;
            margin-bottom: 40px;
        }

        /* Cover Slide */
        .slide.cover .emoji-logo { font-size: 100px; margin-bottom: 20px; }
        .slide.cover .tagline {
            font-size: 20px;
            color: #00d4ff;
            margin-top: 30px;
            letter-spacing: 4px;
        }
        .slide.cover .meta {
            margin-top: 60px;
            font-size: 16px;
            color: #666;
        }

        /* Grid */
        .grid {
            display: grid;
            gap: 20px;
            width: 100%;
            margin-top: 20px;
        }
        .grid-2 { grid-template-columns: 1fr 1fr; }
        .grid-3 { grid-template-columns: 1fr 1fr 1fr; }
        .grid-4 { grid-template-columns: 1fr 1fr 1fr 1fr; }

        .card {
            background: #111830;
            border: 1px solid #1a2a4a;
            border-radius: 12px;
            padding: 28px;
            text-align: center;
            transition: transform 0.2s;
        }
        .card:hover { transform: translateY(-4px); border-color: #00d4ff44; }
        .card .icon { font-size: 40px; margin-bottom: 12px; }
        .card h4 { font-size: 18px; color: #fff; margin-bottom: 8px; }
        .card p { font-size: 14px; color: #888; text-align: center; line-height: 1.6; }

        /* Table */
        .ppt-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        .ppt-table th, .ppt-table td {
            padding: 16px 20px;
            border: 1px solid #1a2a4a;
            text-align: left;
            font-size: 16px;
        }
        .ppt-table th {
            background: #0f2040;
            color: #00d4ff;
            font-size: 15px;
        }
        .ppt-table td { color: #ccc; }

        /* Stats */
        .stats {
            display: flex;
            gap: 60px;
            margin-top: 40px;
        }
        .stat { text-align: center; }
        .stat .number {
            font-size: 56px;
            font-weight: bold;
            background: linear-gradient(135deg, #00d4ff, #00ff88);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .stat .label { font-size: 16px; color: #888; margin-top: 8px; }

        /* Architecture */
        .arch {
            background: #111830;
            border-radius: 12px;
            padding: 30px;
            font-family: 'Consolas', monospace;
            font-size: 14px;
            white-space: pre;
            line-height: 1.5;
            color: #b0c4de;
            width: 100%;
            margin-top: 20px;
        }
        .arch .highlight { color: #00d4ff; }

        /* Flow */
        .flow {
            display: flex;
            align-items: center;
            gap: 16px;
            margin-top: 30px;
            flex-wrap: wrap;
            justify-content: center;
        }
        .flow-item {
            background: #111830;
            border: 1px solid #1a2a4a;
            border-radius: 8px;
            padding: 16px 24px;
            text-align: center;
        }
        .flow-item .step-num {
            font-size: 12px;
            color: #00d4ff;
            margin-bottom: 4px;
        }
        .flow-item .step-text { font-size: 15px; }
        .flow-arrow { font-size: 24px; color: #00d4ff; }

        /* Comparison */
        .compare {
            display: flex;
            gap: 40px;
            width: 100%;
            margin-top: 20px;
        }
        .compare-col {
            flex: 1;
            border-radius: 12px;
            padding: 30px;
        }
        .compare-col.old {
            background: #1a1010;
            border: 1px solid #442222;
        }
        .compare-col.new {
            background: #101a1a;
            border: 1px solid #224444;
        }
        .compare-col h4 {
            font-size: 20px;
            margin-bottom: 16px;
        }
        .compare-col.old h4 { color: #ff6666; }
        .compare-col.new h4 { color: #00ff88; }
        .compare-col ul { list-style: none; }
        .compare-col li {
            padding: 8px 0;
            font-size: 16px;
            color: #bbb;
        }

        /* Bullet list */
        .bullet-list {
            width: 100%;
            text-align: left;
            margin-top: 20px;
        }
        .bullet-list li {
            font-size: 20px;
            padding: 12px 0;
            list-style: none;
            color: #ccc;
            border-bottom: 1px solid #1a2a4a;
        }
        .bullet-list li strong { color: #00d4ff; }

        /* End slide */
        .slide.end .big-emoji { font-size: 120px; margin-bottom: 30px; }
        .slide.end .cta {
            margin-top: 40px;
            padding: 16px 40px;
            background: linear-gradient(135deg, #00d4ff, #0084ff);
            border-radius: 8px;
            font-size: 18px;
            color: #fff;
        }
    </style>
</head>
<body>

<div class="tips">← → 翻页 | F11 全屏 | F5 从头开始</div>
<div class="page-num" id="pageNum">1 / 10</div>

<div class="nav">
